PROFILE_NAME=w05-asan-nts
PROFILE_BUILD_TYPE=debug
PROFILE_THREAD_SAFETY=nts
PROFILE_SANITIZER=address
PROFILE_WAVE=5
PROFILE_LOCALE=C
PROFILE_TIMEZONE=UTC
PROFILE_SEED=20260719
if [[ $(uname -s) == Darwin && -z ${ASAN_OPTIONS+x} ]]; then
    export ASAN_OPTIONS=abort_on_error=1:detect_leaks=0:halt_on_error=1:strict_string_checks=1
fi
PROFILE_CONFIGURE_FLAGS=(
    --enable-debug
    --disable-zts
    --enable-address-sanitizer
    --enable-native-mir-test
)
