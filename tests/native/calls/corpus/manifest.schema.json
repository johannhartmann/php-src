{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "cases": {
      "type": "array",
      "minItems": 24,
      "items": {
        "type": "object",
        "required": ["id", "source", "function", "status", "mirl", "wave"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "source": {"type": "string", "pattern": "^tests/native/calls/corpus/cases/.+\\.php$"},
          "function": {"type": "string"},
          "status": {"enum": ["accepted", "rejected"]},
          "mirl": {"type": "string", "pattern": "^MIRL[0-9]{4}$"},
          "wave": {"type": ["string", "null"], "pattern": "^W[0-9]{2}$"},
          "compiler_mode": {"enum": ["ignore_user_functions"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
