{
  "$id": "https://php.net/schemas/native/benchmark-scenario-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "config": {"type": "object"},
    "expected_checksum": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "php_file": {"minLength": 1, "type": "string"},
    "scenario_id": {"pattern": "^[a-z0-9][a-z0-9_-]*$", "type": "string"},
    "schema_version": {"const": 1},
    "title": {"minLength": 1, "type": "string"},
    "warmup_calls": {"minimum": 0, "type": "integer"}
  },
  "required": ["config", "expected_checksum", "php_file", "scenario_id", "schema_version", "title", "warmup_calls"],
  "type": "object"
}
