{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://php.net/native-engine/w04-opcode-profile.schema.json",
  "title": "W04 source-backed opcode profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "mir_contract_version",
    "sources",
    "active_opcode_count",
    "reserved_opcode_numbers",
    "proof_catalog",
    "opcodes"
  ],
  "properties": {
    "format_version": {
      "const": 1
    },
    "mir_contract_version": {
      "const": "1.3"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "w01",
        "w03"
      ],
      "properties": {
        "w01": {
          "$ref": "#/$defs/source"
        },
        "w03": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "active_opcode_count": {
      "type": "integer",
      "minimum": 1
    },
    "reserved_opcode_numbers": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "proof_catalog": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "opcodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/opcode"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "source_commit",
        "active_opcode_count"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "active_opcode_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "opcode": {
      "type": "object",
      "required": [
        "number",
        "opcode",
        "classification",
        "owner",
        "provider_owner",
        "deferred_wave",
        "proofs",
        "mir_opcodes",
        "rationale",
        "w01",
        "source_refs"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 0
        },
        "opcode": {
          "type": "string",
          "pattern": "^ZEND_[A-Z0-9_]+$"
        },
        "classification": {
          "enum": [
            "required",
            "conditional",
            "deferred"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "provider_owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "deferred_wave": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^W[0-9]{2}$"
        },
        "proofs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "mir_opcodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "w01": {
          "type": "object"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
