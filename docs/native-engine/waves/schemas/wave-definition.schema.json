{
  "$id": "https://php.net/schemas/native-engine/wave-definition-1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "format_version": {"const": "1.0.0"},
    "migration_policy": {"minLength": 1, "type": "string"},
    "waves": {
      "items": {"$ref": "#/$defs/wave"},
      "maxItems": 19,
      "minItems": 19,
      "type": "array"
    }
  },
  "required": ["format_version", "migration_policy", "waves"],
  "title": "Native engine wave definition",
  "type": "object",
  "$defs": {
    "task": {
      "additionalProperties": false,
      "properties": {
        "owned_paths": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
        "requires_clean_worktree": {"type": "boolean"},
        "role": {"minLength": 1, "type": "string"},
        "task_id": {"$ref": "#/$defs/taskId"},
        "title": {"minLength": 1, "type": "string"}
      },
      "required": ["task_id", "title", "role", "owned_paths", "requires_clean_worktree"],
      "type": "object"
    },
    "taskId": {
      "pattern": "^W(?:0[0-9]|1[0-8])-[A-Za-z0-9][A-Za-z0-9-]*$",
      "type": "string"
    },
    "wave": {
      "additionalProperties": false,
      "properties": {
        "dependencies": {"items": {"$ref": "#/$defs/waveId"}, "type": "array"},
        "expected_base_commit": {
          "oneOf": [
            {"pattern": "^[0-9a-f]{40}$", "type": "string"},
            {"type": "null"}
          ]
        },
        "goal": {"minLength": 1, "type": "string"},
        "optional_gate_ids": {"items": {"$ref": "#/$defs/taskId"}, "type": "array"},
        "parallel_tracks": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
        "required_gate_ids": {"items": {"$ref": "#/$defs/taskId"}, "type": "array"},
        "responsible_paths": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
        "roles": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
        "tasks": {"items": {"$ref": "#/$defs/task"}, "type": "array"},
        "title": {"minLength": 1, "type": "string"},
        "wave_id": {"$ref": "#/$defs/waveId"}
      },
      "required": ["wave_id", "title", "goal", "dependencies", "parallel_tracks", "required_gate_ids", "optional_gate_ids", "responsible_paths", "roles", "expected_base_commit", "tasks"],
      "type": "object"
    },
    "waveId": {"pattern": "^W(?:0[0-9]|1[0-8])$", "type": "string"}
  }
}
