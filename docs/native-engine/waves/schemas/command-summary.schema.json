{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://php.net/schemas/native-engine/command-summary-2.0.0.json",
  "title": "Native-engine reproducible command summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "command_id", "argv", "environment_profile", "exit_code", "stdout_sha256", "stderr_sha256", "duration_ms"],
  "properties": {
    "format_version": {"const": "2.0.0"},
    "command_id": {"pattern": "^[a-z0-9][a-z0-9-]*$", "type": "string"},
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:[\\\\/]).*$"}
    },
    "environment_profile": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "exit_code": {"type": "integer"},
    "stdout_sha256": {"$ref": "#/$defs/sha256"},
    "stderr_sha256": {"$ref": "#/$defs/sha256"},
    "raw_log": {"$ref": "#/$defs/relativePath"},
    "raw_log_sha256": {"$ref": "#/$defs/sha256"},
    "raw_log_size_bytes": {"type": "integer", "minimum": 1},
    "duration_ms": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"}
  }
}
