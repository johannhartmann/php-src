{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://php.net/schemas/native-engine/review-evidence-2.0.0.json",
  "title": "Native-engine committed review evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "review_id", "review_kind", "subject_commit", "subject_tree", "reviewer", "status", "findings"],
  "properties": {
    "format_version": {"const": "2.0.0"},
    "review_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"},
    "review_kind": {"enum": ["semantics", "evidence-history-capability"]},
    "subject_commit": {"$ref": "#/$defs/commit"},
    "subject_tree": {"$ref": "#/$defs/commit"},
    "reviewer": {"type": "string", "minLength": 1},
    "status": {"enum": ["pass", "fail"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "path", "line", "invariant", "scenario", "fix"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {"enum": ["P0", "P1", "P2", "P3"]},
          "path": {"$ref": "#/$defs/relativePath"},
          "line": {"type": "integer", "minimum": 1},
          "invariant": {"type": "string", "minLength": 1},
          "scenario": {"type": "string", "minLength": 1},
          "fix": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"}
  }
}
