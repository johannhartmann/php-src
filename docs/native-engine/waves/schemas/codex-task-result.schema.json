{
  "$id": "https://php.net/schemas/native-engine/codex-task-result-1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {"task_id": {"const": "W05-integration-gate"}},
        "required": ["task_id"]
      },
      "then": {
        "properties": {"head_commit": {"type": "null"}},
        "required": ["tested_head_commit", "seal_subject", "phase_receipts"]
      }
    }
  ],
  "properties": {
    "acceptance_criteria": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "criterion_id": {"minLength": 1, "type": "string"},
          "description": {"minLength": 1, "type": "string"},
          "status": {"$ref": "#/$defs/status"}
        },
        "required": ["criterion_id", "description", "status"],
        "type": "object"
      },
      "type": "array"
    },
    "actual_base_commit": {"$ref": "#/$defs/commit"},
    "blockers": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
    "branch": {"minLength": 1, "type": "string"},
    "changed_paths": {"items": {"$ref": "#/$defs/relativePath"}, "type": "array"},
    "expected_base_commit": {"$ref": "#/$defs/commit"},
    "format_version": {"const": "1.0.0"},
    "gate_evidence": {
      "items": {"$ref": "#/$defs/gateEvidence"},
      "type": "array"
    },
    "head_commit": {
      "oneOf": [
        {"$ref": "#/$defs/commit"},
        {"type": "null"}
      ]
    },
    "phase_receipts": {
      "items": {"$ref": "#/$defs/phaseReceipt"},
      "minItems": 4,
      "type": "array"
    },
    "seal_subject": {"$ref": "#/$defs/sealSubject"},
    "tested_head_commit": {"$ref": "#/$defs/commit"},
    "risks": {"items": {"minLength": 1, "type": "string"}, "type": "array"},
    "status": {"$ref": "#/$defs/status"},
    "task_id": {
      "pattern": "^W(?:0[0-9]|1[0-8])-[A-Za-z0-9][A-Za-z0-9-]*$",
      "type": "string"
    },
    "tests": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact": {"$ref": "#/$defs/artifact"},
          "command": {"minLength": 1, "type": "string"},
          "duration_ms": {"minimum": 0, "type": ["integer", "null"]},
          "exit_code": {"type": ["integer", "null"]},
          "status": {"$ref": "#/$defs/status"}
        },
        "required": ["command", "status", "exit_code", "duration_ms", "artifact"],
        "type": "object"
      },
      "type": "array"
    },
    "timestamp": {"format": "date-time", "type": "string"},
    "worktree_clean": {"type": "boolean"}
  },
  "required": [
    "format_version",
    "task_id",
    "status",
    "expected_base_commit",
    "actual_base_commit",
    "head_commit",
    "branch",
    "changed_paths",
    "tests",
    "acceptance_criteria",
    "gate_evidence",
    "risks",
    "blockers",
    "worktree_clean",
    "timestamp"
  ],
  "title": "Codex native-engine task result",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "local"}}, "required": ["kind"]},
          "then": {
            "properties": {
              "reference": {
                "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
              }
            }
          }
        }
      ],
      "properties": {
        "kind": {"enum": ["local", "ci"]},
        "reference": {"minLength": 1, "type": "string"}
      },
      "required": ["kind", "reference"],
      "type": "object"
    },
    "commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "gateEvidence": {
      "additionalProperties": false,
      "properties": {
        "artifact": {"$ref": "#/$defs/artifact"},
        "format_version": {"const": "1.0.0"},
        "gate_id": {
          "pattern": "^W(?:0[0-9]|1[0-8])-[A-Za-z0-9][A-Za-z0-9-]*$",
          "type": "string"
        },
        "status": {"$ref": "#/$defs/status"},
        "summary": {"minLength": 1, "type": "string"},
        "wave_id": {"pattern": "^W(?:0[0-9]|1[0-8])$", "type": "string"}
      },
      "required": ["format_version", "wave_id", "gate_id", "status", "summary", "artifact"],
      "type": "object"
    },
    "relativePath": {
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$",
      "type": "string"
    },
    "phaseReceipt": {
      "additionalProperties": false,
      "properties": {
        "changed_paths": {
          "items": {"$ref": "#/$defs/relativePath"},
          "type": "array"
        },
        "command_summary_digests": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "command_id": {
                "pattern": "^[a-z0-9][a-z0-9-]*$",
                "type": "string"
              },
              "path": {"$ref": "#/$defs/relativePath"},
              "sha256": {"$ref": "#/$defs/sha256"}
            },
            "required": ["command_id", "path", "sha256"],
            "type": "object"
          },
          "type": "array"
        },
        "commit": {"$ref": "#/$defs/commit"},
        "format_version": {"const": "1.0.0"},
        "parent": {"$ref": "#/$defs/commit"},
        "phase_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$",
          "type": "string"
        },
        "tree": {"$ref": "#/$defs/commit"}
      },
      "required": [
        "format_version",
        "phase_id",
        "commit",
        "tree",
        "parent",
        "changed_paths",
        "command_summary_digests"
      ],
      "type": "object"
    },
    "sealSubject": {
      "additionalProperties": false,
      "properties": {
        "receipt_path": {"$ref": "#/$defs/relativePath"},
        "receipt_sha256": {"$ref": "#/$defs/sha256"}
      },
      "required": ["receipt_path", "receipt_sha256"],
      "type": "object"
    },
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "status": {"enum": ["pending", "running", "pass", "fail", "blocked", "skipped"]}
  }
}
