{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://php.net/schemas/native-engine/wave-receipt-2.0.0.json",
  "title": "Native-engine durable wave receipt v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version", "wave_id", "state", "verification_level",
    "subject_commit", "subject_tree", "definition", "profiles", "coverage",
    "command_summaries", "binary_manifests", "reviews",
    "dependency_receipts", "phase_receipts", "capability_ids",
    "semantic_debt_ids", "codegen_eligible"
  ],
  "properties": {
    "format_version": {"const": "2.0.0"},
    "wave_id": {"$ref": "#/$defs/waveId"},
    "state": {"enum": ["unsealed", "revalidated", "sealed", "invalid"]},
    "verification_level": {"enum": ["metadata", "reproducible", "full"]},
    "subject_commit": {"$ref": "#/$defs/commit"},
    "subject_tree": {"$ref": "#/$defs/commit"},
    "definition": {"$ref": "#/$defs/digestRef"},
    "profiles": {"type": "array", "items": {"$ref": "#/$defs/digestRef"}},
    "coverage": {"$ref": "#/$defs/digestRef"},
    "command_summaries": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["command_id", "path", "sha256"],
        "properties": {
          "command_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "path": {"$ref": "#/$defs/relativePath"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "binary_manifests": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["binary_id", "role", "artifact_path", "sha256", "git_commit", "git_tree", "configure_args", "toolchain"],
        "properties": {
          "binary_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "role": {"enum": ["reference", "candidate"]},
          "artifact_path": {"$ref": "#/$defs/relativePath"},
          "sha256": {"$ref": "#/$defs/sha256"},
          "git_commit": {"$ref": "#/$defs/commit"},
          "git_tree": {"$ref": "#/$defs/commit"},
          "configure_args": {"type": "array", "items": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:[\\\\/]).*$"}},
          "toolchain": {"type": "string", "minLength": 1}
        }
      }
    },
    "reviews": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/digestRef"}},
    "dependency_receipts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["wave_id", "path", "sha256"],
        "properties": {
          "wave_id": {"$ref": "#/$defs/waveId"},
          "path": {"$ref": "#/$defs/relativePath"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "phase_receipts": {
      "type": "array", "minItems": 4,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["format_version", "phase_id", "commit", "tree", "parent", "changed_paths", "command_summary_digests"],
        "properties": {
          "format_version": {"const": "1.0.0"},
          "phase_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"},
          "commit": {"$ref": "#/$defs/commit"},
          "tree": {"$ref": "#/$defs/commit"},
          "parent": {"$ref": "#/$defs/commit"},
          "changed_paths": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}},
          "command_summary_digests": {
            "type": "array",
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["command_id", "path", "sha256"],
              "properties": {
                "command_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
                "path": {"$ref": "#/$defs/relativePath"},
                "sha256": {"$ref": "#/$defs/sha256"}
              }
            }
          }
        }
      }
    },
    "capability_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
    "semantic_debt_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
    "codegen_eligible": {"const": false}
  },
  "$defs": {
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "waveId": {"type": "string", "pattern": "^W(?:0[0-9]|1[0-8])$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"},
    "digestRef": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
