{
  "$id": "https://php.net/schemas/native-engine/gate-evidence-1.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact": {
      "$ref": "#/$defs/artifact"
    },
    "format_version": {
      "const": "1.0.0"
    },
    "gate_id": {
      "pattern": "^W(?:0[0-9]|1[0-8])-[A-Za-z0-9][A-Za-z0-9-]*$",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "summary": {
      "minLength": 1,
      "type": "string"
    },
    "wave_id": {
      "pattern": "^W(?:0[0-9]|1[0-8])$",
      "type": "string"
    }
  },
  "required": [
    "format_version",
    "wave_id",
    "gate_id",
    "status",
    "summary",
    "artifact"
  ],
  "title": "Native engine gate evidence",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "local"}}, "required": ["kind"]},
          "then": {
            "properties": {
              "reference": {
                "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
              }
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": ["local", "ci"]
        },
        "reference": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["kind", "reference"],
      "type": "object"
    },
    "status": {
      "enum": ["pending", "running", "pass", "fail", "blocked", "skipped"]
    }
  }
}
