{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "wave", "start_commit", "writer_branch", "phases", "read_only_phases", "repair_phase_aliases"],
  "properties": {
    "format_version": {"const": 1},
    "wave": {"const": "W06"},
    "start_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "writer_branch": {"const": "integration/wave-06"},
    "phases": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase_id", "order", "paths"],
        "properties": {
          "phase_id": {"type": "string", "pattern": "^W06-[A-Za-z0-9-]+$"},
          "order": {"type": "integer", "minimum": 0},
          "paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "read_only_phases": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
    "repair_phase_aliases": {"type": "object", "minProperties": 2, "additionalProperties": {"type": "string"}}
  }
}
