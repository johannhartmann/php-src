{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "mir_contract_version", "alias_merge", "call_transfer", "invalid_transitions", "ownership_merge", "separation", "transitions"],
  "properties": {
    "format_version": {"const": 1},
    "mir_contract_version": {"const": "1.9"},
    "alias_merge": {"type": "object"},
    "call_transfer": {"type": "object"},
    "invalid_transitions": {"type": "array", "minItems": 8, "uniqueItems": true, "items": {"type": "string"}},
    "ownership_merge": {"type": "object"},
    "separation": {"type": "object"},
    "transitions": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "from", "to", "cleanup_obligation"],
        "properties": {
          "action": {"enum": ["borrow", "copy_addref", "move", "release", "transfer_to_callee", "transfer_from_callee"]},
          "from": {"type": "array", "minItems": 1, "items": {"enum": ["immortal", "unique", "shared", "unknown"]}},
          "to": {"type": "string", "minLength": 1},
          "cleanup_obligation": {"type": "boolean"}
        }
      }
    }
  }
}
