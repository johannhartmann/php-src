    {"case": "by_ref_named_unpack_variadic_placeholder_or_refcounted_argument", "diagnostic": "MIRL0024"},
    {"case": "argument_count_mismatch_or_default", "diagnostic": "MIRL0025"},
    {"case": "unproved_or_refcounted_result", "diagnostic": "MIRL0026"},
    {"case": "protected_region", "diagnostic": "MIRL0027"},
    {"case": "allocation_or_plan_publication_failure", "diagnostic": "MIRL0028"}
  ]
