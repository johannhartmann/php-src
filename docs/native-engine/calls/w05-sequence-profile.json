{
  "accepted_grammar": {
    "argument": {
      "mode": "by_value",
      "opcodes": [
        "ZEND_SEND_VAL",
        "ZEND_SEND_VAL_EX",
        "ZEND_SEND_VAR",
        "ZEND_SEND_VAR_EX"
      ],
      "ordinal": "strictly_increasing_zero_based",
      "types": [
        "null",
        "bool",
        "long",
        "double"
      ]
    },
    "callee_entry": {
      "opcode": "ZEND_RECV",
      "explicit_argument_count": "required_num_args_through_num_args",
      "parameter_modes": "ordered_unbounded_table"
    },
    "finish": {
      "opcodes": [
        "ZEND_DO_UCALL",
        "ZEND_DO_FCALL"
      ],
      "proof": "exact_user_target"
    },
    "init": {
      "opcode": "ZEND_INIT_FCALL",
      "target": "exact_direct_same_script_user_function"
    },
    "nesting": "balanced_lifo_init_send_do",
    "result": "unused_or_exact_non_refcounted_scalar_summary"
  },
  "atomicity": "plan_complete_sequence_before_mir_mutation",
  "capabilities": [
    "scalar_semantics",
    "reducible_control_flow",
    "direct_user_call_sequence",
    "caller_frame_descriptor",
    "callee_entry_descriptor",
    "abstract_call_effects"
  ],
  "codegen_eligible": false,
  "debts": [
    "call_execution",
    "exception_cleanup",
    "refcounted_transfer",
    "protected_continuation",
    "dynamic_target_resolution",
    "observer_interop",
    "cow_indirect_semantics",
    "internal_c_abi_interop"
  ],
  "format_version": 2,
  "modeled": true,
  "proofs": [
    "complete_reachable_call_scan",
    "atomic_init_send_do_plan",
    "exact_direct_same_script_user_target",
    "balanced_nested_call_stack",
    "positional_by_value_arguments",
    "exact_non_refcounted_scalar_arguments",
    "all_arguments_explicitly_supplied",
    "normalized_named_arguments_have_complete_static_ordinals",
    "no_runtime_named_container_unpack_variadic_placeholder_or_default_materialization",
    "exact_self_target_is_direct",
    "no_by_reference",
    "result_unused_or_exact_scalar",
    "complete_caller_callee_frames",
    "no_protected_region"
  ],
  "rejections": [
