{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "format_version": {"const": 1},
    "phases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "commands_provided": {"items": {"type": "string"}, "type": "array"},
          "commands_used": {"items": {"type": "string"}, "type": "array"},
          "order": {"minimum": 0, "type": "integer"},
          "paths": {"items": {"type": "string"}, "type": "array"},
          "phase_id": {"type": "string"},
          "root_contracts_mutable": {"type": "boolean"},
          "task_ids": {"items": {"type": "string"}, "minItems": 1, "type": "array"},
          "write_mode": {"enum": ["single_writer", "read_only"]}
        },
        "required": ["commands_provided", "commands_used", "order", "paths", "phase_id", "root_contracts_mutable", "task_ids", "write_mode"],
        "type": "object"
      },
      "type": "array"
    },
    "shared_serial_paths": {"items": {"type": "string"}, "type": "array"},
    "writer_branch": {"const": "integration/wave-05"}
  },
  "required": ["format_version", "phases", "shared_serial_paths", "writer_branch"],
  "type": "object"
}
