{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://php.net/schemas/native-engine/tpde-required-capabilities.schema.json",
    "title": "Pinned TPDE capability analysis",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "format_version",
        "repository",
        "tpde_commit",
        "primary_target",
        "secondary_target",
        "classifications",
        "reviewed_source_files",
        "capabilities"
    ],
    "properties": {
        "format_version": { "const": "1.0.0" },
        "repository": { "const": "tpde2/tpde" },
        "tpde_commit": {
            "const": "338d41890e424b058e2053b6a5787e1348e3dd57"
        },
        "primary_target": { "const": "linux-elf-x86-64" },
        "secondary_target": { "const": "aarch64-analyzed-unreleased" },
        "classifications": {
            "type": "array",
            "uniqueItems": true,
            "items": {
                "enum": [
                    "blocked",
                    "covered",
                    "not_needed",
                    "php_shim",
                    "tpde_core_patch",
                    "tpde_extension"
                ]
            }
        },
        "reviewed_source_files": {
            "type": "array",
            "minItems": 17,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
        },
        "capabilities": {
            "type": "array",
            "minItems": 27,
            "items": { "$ref": "#/$defs/capability" }
        }
    },
    "$defs": {
        "source_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "symbol", "start_line", "end_line", "evidence"],
            "properties": {
                "path": { "type": "string", "minLength": 1 },
                "symbol": { "type": "string", "minLength": 1 },
                "start_line": { "type": "integer", "minimum": 1 },
                "end_line": { "type": "integer", "minimum": 1 },
                "evidence": { "type": "string", "minLength": 1 }
            }
        },
        "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "impact"],
            "properties": {
                "status": {
                    "enum": ["required", "analyzed_unreleased", "not_applicable"]
                },
                "impact": { "type": "string", "minLength": 1 }
            }
        },
        "capability": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "critical",
                "php_requirement",
                "motivating_contract",
                "classification",
                "source_refs",
                "existing_behavior",
                "missing_behavior",
                "minimal_api_or_shim",
                "owner",
                "upstreamability",
                "target_impact",
                "required_tests",
                "blocker_id",
                "decision_id"
            ],
            "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
                "critical": { "const": true },
                "php_requirement": { "type": "string", "minLength": 1 },
                "motivating_contract": { "type": "string", "minLength": 1 },
                "classification": {
                    "enum": [
                        "covered",
                        "php_shim",
                        "tpde_extension",
                        "tpde_core_patch",
                        "blocked",
                        "not_needed"
                    ]
                },
                "source_refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/source_ref" }
                },
                "existing_behavior": { "type": "string", "minLength": 1 },
                "missing_behavior": { "type": "string", "minLength": 1 },
                "minimal_api_or_shim": { "type": "string", "minLength": 1 },
                "owner": { "enum": ["php", "tpde", "shared"] },
                "upstreamability": {
                    "enum": [
                        "not_applicable",
                        "php_local",
                        "good_candidate",
                        "requires_core_review"
                    ]
                },
                "target_impact": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["x86_64", "aarch64"],
                    "properties": {
                        "x86_64": { "$ref": "#/$defs/target" },
                        "aarch64": { "$ref": "#/$defs/target" }
                    }
                },
                "required_tests": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                },
                "blocker_id": { "type": ["string", "null"] },
                "decision_id": { "type": ["string", "null"] }
            }
        }
    }
}
