{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "capability_id": {"pattern": "^[a-z][a-z0-9_]*$", "type": "string"},
          "description": {"minLength": 1, "type": "string"},
          "open_debts": {
            "items": {"pattern": "^[a-z][a-z0-9_]*$", "type": "string"},
            "type": "array"
          },
          "prerequisites": {
            "items": {"pattern": "^[a-z][a-z0-9_]*$", "type": "string"},
            "type": "array"
          },
          "wave_id": {"pattern": "^W(?:0[0-9]|1[0-8])$", "type": "string"}
        },
        "required": ["capability_id", "wave_id", "description", "prerequisites", "open_debts"],
        "type": "object"
      },
      "type": "array"
    },
    "format_version": {"const": "1.0.0"}
  },
  "required": ["format_version", "capabilities"],
  "type": "object"
}
