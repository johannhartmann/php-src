{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://php.net/schemas/native-engine/capability-registry-1.0.0.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "entries"],
  "properties": {
    "format_version": {"const": "1.0.0"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "transport_id", "introduced_by_wave", "prerequisites", "closes_debts", "incompatible_with", "description"],
        "properties": {
          "kind": {"enum": ["capability", "semantic_debt"]},
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "transport_id": {"type": "integer", "minimum": 1, "maximum": 4294967295},
          "introduced_by_wave": {"type": "string", "pattern": "^W(?:0[0-9]|1[0-8])$"},
          "prerequisites": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
          "closes_debts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
          "incompatible_with": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
          "description": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
